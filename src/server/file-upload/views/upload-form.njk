{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="/file-upload/add" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      <p class="govuk-body">
        <strong>{{ t('pages.fileUpload.upload.material') }}:</strong> {{ material }}
      </p>
      <p class="govuk-body">
        <strong>{{ t('pages.fileUpload.upload.year') }}:</strong> {{ year }}
      </p>

      <form action="{{ action }}" method="post" enctype="multipart/form-data">

        <div class="govuk-form-group" data-testid="field-group-file">
          <label class="govuk-label govuk-label--m" for="file">
            {{ t('pages.fileUpload.upload.fileLabel') }}
          </label>
          <div class="govuk-hint">
            {{ t('pages.fileUpload.upload.fileHint') }}
          </div>
          <input
            class="govuk-file-upload"
            id="file"
            name="file"
            type="file"
            accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
            data-testid="input-file">
        </div>

        <button type="submit" class="govuk-button" data-module="govuk-button" data-testid="upload-button">
          {{ t('pages.fileUpload.upload.uploadButton') }}
        </button>

      </form>

    </div>
  </div>
{% endblock %}
