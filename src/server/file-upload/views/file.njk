{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" data-testid="error-summary">
          <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
          <div class="govuk-error-summary__body">
            <p>{{ error }}</p>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      {% if file %}
        <dl class="govuk-summary-list" data-testid="file-details">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.fileUpload.file.filename') }}</dt>
            <dd class="govuk-summary-list__value">{{ file.filename }}</dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.fileUpload.file.material') }}</dt>
            <dd class="govuk-summary-list__value">{{ file.material }}</dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.fileUpload.file.year') }}</dt>
            <dd class="govuk-summary-list__value">{{ file.yearOfAccreditation }}</dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.fileUpload.file.contentType') }}</dt>
            <dd class="govuk-summary-list__value">{{ file.contentType }}</dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.fileUpload.file.uploadedAt') }}</dt>
            <dd class="govuk-summary-list__value">{{ file.uploadedAt | formatDate }}</dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.fileUpload.file.status') }}</dt>
            <dd class="govuk-summary-list__value">
              <strong class="govuk-tag {% if file.scanStatus === 'Clean' %}govuk-tag--green{% elif file.scanStatus === 'Infected' %}govuk-tag--red{% else %}govuk-tag--yellow{% endif %}">
                {{ t('pages.fileUpload.list.scanStatuses.' + file.scanStatus) }}
              </strong>
            </dd>
          </div>
        </dl>

        {% if file.scanStatus === 'Clean' %}
          <a href="/file-upload/{{ file.fileUploadId }}/download" class="govuk-button govuk-button--secondary" data-testid="download-button">
            {{ t('pages.fileUpload.file.download') }}
          </a>
        {% endif %}
      {% endif %}

    </div>
  </div>
{% endblock %}
