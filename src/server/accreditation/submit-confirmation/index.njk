{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <div class="govuk-panel govuk-panel--confirmation" data-testid="confirmation-panel">
        <h1 class="govuk-panel__title" data-testid="panel-heading">
          {{ panelHeading }}
        </h1>
        <div class="govuk-panel__body" data-testid="panel-body">
          {{ panelBodyPrefix }} {{ materialDisplay }}:
          <br>
          <strong data-testid="application-reference">{{ accreditationReference }}</strong>
          {% if caseManagementReference %}
          <br>
          {{ caseReferenceLabel }}
          <br>
          <strong data-testid="case-management-reference">{{ caseManagementReference }}</strong>
          {% endif %}
        </div>
      </div>

      <div class="govuk-notification-banner" role="region" aria-labelledby="govuk-notification-banner-title" data-module="govuk-notification-banner">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="govuk-notification-banner-title">
            Important
          </h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading" data-testid="payment-text">
          {{ paymentText }}
          </p>
        </div>
      </div>

      <p class="govuk-body">
        <a href="/accreditation/view-payment-details/{{ applicationId }}" class="govuk-link" data-testid="view-payment-details-link">{{ viewInvoice }}</a>
      </p>

      <p class="govuk-body">
        <a href="/" class="govuk-link" data-testid="return-home-link">{{ returnHome }}</a>
      </p>

    </div>
  </div>
{% endblock %}
