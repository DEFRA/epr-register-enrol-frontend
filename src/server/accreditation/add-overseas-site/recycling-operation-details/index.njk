{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" data-testid="error-summary">
          <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li><a href="#recycling-operation-code">{{ error }}</a></li>
            </ul>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      <form method="post">
        <input type="hidden" name="crumb" value="{{ crumb }}">

        <div class="govuk-form-group{% if error %} govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="recycling-operation-code">{{ label }}</label>
          {% if error %}
            <p class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ error }}</p>
          {% endif %}
          <select class="govuk-select{% if error %} govuk-select--error{% endif %}"
                  id="recycling-operation-code"
                  name="recyclingOperationCode"
                  data-testid="recycling-operation-select">
            <option value="">{{ selectDefault }}</option>
            {% for option in options %}
              <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}
                      data-testid="option-{{ option.value }}">
                {{ option.text }}
              </option>
            {% endfor %}
          </select>
        </div>

        <button type="submit" class="govuk-button" data-module="govuk-button"
                data-testid="continue-button">
          {{ continueButton }}
        </button>
      </form>

      <a href="{{ cancelUrl }}" class="govuk-link" data-testid="cancel-link">{{ cancelLink }}</a>

    </div>
  </div>
{% endblock %}
