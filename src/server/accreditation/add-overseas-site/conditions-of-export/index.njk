{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" data-testid="error-summary">
          <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li><a href="#conditionsOfExport">{{ error }}</a></li>
            </ul>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      <p class="govuk-body">{{ intro }}</p>

      <ul class="govuk-list govuk-list--bullet" data-testid="conditions-list">
        {% for condition in conditions %}
          <li>{{ condition }}</li>
        {% endfor %}
      </ul>

      <form method="post">
        <input type="hidden" name="crumb" value="{{ crumb }}">

        <div class="govuk-form-group{% if error %} govuk-form-group--error{% endif %}">
          <fieldset class="govuk-fieldset">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
              <h2 class="govuk-fieldset__heading">{{ questionLabel }}</h2>
            </legend>
            {% if error %}
              <p class="govuk-error-message" id="conditionsOfExport-error">
                <span class="govuk-visually-hidden">Error:</span> {{ error }}
              </p>
            {% endif %}
            <div class="govuk-radios" data-module="govuk-radios" id="conditionsOfExport">
              <div class="govuk-radios__item">
                <input class="govuk-radios__input"
                       id="conditionsOfExport-yes"
                       name="conditionsOfExport"
                       type="radio"
                       value="yes"
                       {% if selected === 'yes' %}checked{% endif %}
                       data-testid="radio-yes">
                <label class="govuk-label govuk-radios__label" for="conditionsOfExport-yes">
                  {{ yesLabel }}
                </label>
              </div>
              <div class="govuk-radios__item">
                <input class="govuk-radios__input"
                       id="conditionsOfExport-no"
                       name="conditionsOfExport"
                       type="radio"
                       value="no"
                       {% if selected === 'no' %}checked{% endif %}
                       data-testid="radio-no">
                <label class="govuk-label govuk-radios__label" for="conditionsOfExport-no">
                  {{ noLabel }}
                </label>
              </div>
            </div>
          </fieldset>
        </div>

        <button type="submit" class="govuk-button" data-module="govuk-button"
                data-testid="continue-button">
          {{ continueButton }}
        </button>
      </form>

      <a href="{{ cancelUrl }}" class="govuk-link" data-testid="cancel-link">{{ cancelLink }}</a>

    </div>
  </div>
{% endblock %}
