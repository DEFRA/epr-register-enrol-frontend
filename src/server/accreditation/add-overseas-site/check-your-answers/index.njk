{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" data-testid="error-summary">
          <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
          <div class="govuk-error-summary__body">
            <p>{{ error }}</p>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      <dl class="govuk-summary-list" data-testid="summary-list">
        {% for row in rows %}
          <div class="govuk-summary-list__row" data-testid="row-{{ row.testId }}">
            <dt class="govuk-summary-list__key">{{ row.key }}</dt>
            <dd class="govuk-summary-list__value">{{ row.value }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="{{ row.changeUrl }}" data-testid="change-{{ row.testId }}">
                {{ changeLabel }}<span class="govuk-visually-hidden"> {{ row.key }}</span>
              </a>
            </dd>
          </div>
        {% endfor %}
      </dl>

      <form method="post">
        <input type="hidden" name="crumb" value="{{ crumb }}">

        <button type="submit" class="govuk-button" data-module="govuk-button"
                data-testid="submit-button">
          {{ submitButton }}
        </button>
      </form>

      <a href="{{ cancelUrl }}" class="govuk-link" data-testid="cancel-link">{{ cancelLink }}</a>

    </div>
  </div>
{% endblock %}
