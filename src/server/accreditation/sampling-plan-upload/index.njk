{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" data-testid="error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
            <div class="govuk-error-summary__body">
              <p>{{ error }}</p>
            </div>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      <p class="govuk-body">{{ t('pages.samplingPlanUpload.requirements.intro') }}</p>
      <ul class="govuk-list govuk-list--bullet" data-testid="file-requirements">
        <li>{{ t('pages.samplingPlanUpload.requirements.maxSize') }}</li>
        <li>{{ t('pages.samplingPlanUpload.requirements.fileTypes') }}</li>
      </ul>

      {% if files and files.length > 0 %}
        <h2 class="govuk-heading-m" data-testid="uploaded-files-heading">{{ t('pages.samplingPlanUpload.uploadedFilesHeading') }}</h2>
        <table class="govuk-table" data-testid="uploaded-files-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">{{ t('pages.samplingPlanUpload.table.filename') }}</th>
              <th scope="col" class="govuk-table__header">{{ t('pages.samplingPlanUpload.table.dateUploaded') }}</th>
              <th scope="col" class="govuk-table__header">{{ t('pages.samplingPlanUpload.table.uploadedBy') }}</th>
              <th scope="col" class="govuk-table__header">{{ t('pages.samplingPlanUpload.table.status') }}</th>
              <th scope="col" class="govuk-table__header">{{ t('pages.samplingPlanUpload.table.action') }}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for file in files %}
              <tr class="govuk-table__row" data-testid="file-row">
                <td class="govuk-table__cell" data-testid="file-name">{{ file.filename }}</td>
                <td class="govuk-table__cell" data-testid="file-date">{{ file.uploadedAt }}</td>
                <td class="govuk-table__cell" data-testid="file-uploaded-by">{{ file.uploadedBy }}</td>
                <td class="govuk-table__cell" data-testid="file-scan-status">
                  {% if file.scanStatus === 'Infected' %}
                    <strong class="govuk-tag govuk-tag--red">{{ t('pages.samplingPlanUpload.scanStatus.infected') }}</strong>
                  {% elif file.scanStatus === 'Clean' %}
                    <strong class="govuk-tag govuk-tag--green">{{ t('pages.samplingPlanUpload.scanStatus.clean') }}</strong>
                  {% else %}
                    <strong class="govuk-tag govuk-tag--grey">{{ t('pages.samplingPlanUpload.scanStatus.scanning') }}</strong>
                  {% endif %}
                </td>
                <td class="govuk-table__cell">
                  <form method="post" novalidate>
                    <input type="hidden" name="crumb" value="{{ crumb }}">
                    <input type="hidden" name="action" value="deleteFile">
                    <input type="hidden" name="fileId" value="{{ file.fileId }}">
                    <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button" data-testid="delete-file-button">
                      {{ t('pages.samplingPlanUpload.deleteFile') }}<span class="govuk-visually-hidden"> {{ file.filename }}</span>
                    </button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}

      <form method="post" enctype="multipart/form-data" novalidate data-testid="upload-form">
        <input type="hidden" name="crumb" value="{{ crumb }}">
        <input type="hidden" name="action" value="uploadFile">

        <div class="govuk-form-group{% if fileError %} govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="file">
            {{ t('pages.samplingPlanUpload.fileLabel') }}
          </label>
          {% if fileError %}
            <p id="file-error" class="govuk-error-message" data-testid="file-error">
              <span class="govuk-visually-hidden">{{ t('common.error') }}:</span> {{ fileError }}
            </p>
          {% endif %}
          <input class="govuk-file-upload{% if fileError %} govuk-file-upload--error{% endif %}"
                 id="file"
                 name="file"
                 type="file"
                 accept=".pdf,.doc,.docx,.xls,.csv,.png,.tif,.jpg,.msg"
                 {% if fileError %}aria-describedby="file-error"{% endif %}
                 data-testid="file-input">
        </div>

        <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button" data-testid="upload-button">
          {{ t('pages.samplingPlanUpload.uploadButton') }}
        </button>
      </form>

      <form method="post" novalidate data-testid="continue-form">
        <input type="hidden" name="crumb" value="{{ crumb }}">

        <button type="submit" name="action" value="saveAndContinue" class="govuk-button" data-module="govuk-button" data-testid="save-continue-button">
          {{ t('pages.samplingPlanUpload.saveAndContinue') }}
        </button>

        <button type="submit" name="action" value="saveAndComeLater" class="govuk-button govuk-button--secondary" data-module="govuk-button" data-testid="save-come-back-button">
          {{ t('pages.samplingPlanUpload.saveAndComeLater') }}
        </button>
      </form>

    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script>
    (function () {
      var MAX_BYTES = 20 * 1024 * 1024
      var ALLOWED_EXTS = ['pdf','doc','docx','xls','csv','png','tif','jpg','msg']
      var errorTooLarge = {{ t('pages.samplingPlanUpload.validation.fileTooLarge') | dump | safe }}
      var errorInvalidType = {{ t('pages.samplingPlanUpload.validation.invalidType') | dump | safe }}
      var fileInput = document.querySelector('[data-testid="file-input"]')
      var uploadForm = document.querySelector('[data-testid="upload-form"]')
      if (!fileInput || !uploadForm) return
      var formGroup = fileInput.closest('.govuk-form-group')

      function getExt(filename) {
        var parts = (filename || '').split('.')
        return parts.length > 1 ? parts[parts.length - 1].toLowerCase() : ''
      }

      function validate(file) {
        if (!file) return null
        if (ALLOWED_EXTS.indexOf(getExt(file.name)) === -1) return errorInvalidType
        if (file.size > MAX_BYTES) return errorTooLarge
        return null
      }

      function showError(text) {
        formGroup.classList.add('govuk-form-group--error')
        fileInput.classList.add('govuk-file-upload--error')
        var errorEl = document.getElementById('file-error')
        if (!errorEl) {
          errorEl = document.createElement('p')
          errorEl.id = 'file-error'
          errorEl.className = 'govuk-error-message'
          errorEl.setAttribute('data-testid', 'file-error')
          fileInput.insertAdjacentElement('beforebegin', errorEl)
        }
        errorEl.innerHTML = '<span class="govuk-visually-hidden">Error:</span> ' + text
        fileInput.setAttribute('aria-describedby', 'file-error')
        fileInput.value = ''
      }

      function clearError() {
        formGroup.classList.remove('govuk-form-group--error')
        fileInput.classList.remove('govuk-file-upload--error')
        fileInput.removeAttribute('aria-describedby')
        var errorEl = document.getElementById('file-error')
        if (errorEl) errorEl.remove()
      }

      fileInput.addEventListener('change', function () {
        var error = validate(this.files[0])
        if (error) { showError(error) } else { clearError() }
      })

      uploadForm.addEventListener('submit', function (e) {
        var error = validate(fileInput.files[0])
        if (error) {
          e.preventDefault()
          showError(error)
        }
      })
    })()
  </script>
{% endblock %}