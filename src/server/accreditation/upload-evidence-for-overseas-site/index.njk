{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" data-testid="error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
            <div class="govuk-error-summary__body">
              <p>{{ error }}</p>
            </div>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      {% if sites and sites.length > 0 %}
        <table class="govuk-table" data-testid="sites-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">{{ t('pages.uploadEvidenceList.table.siteName') }}</th>
              <th scope="col" class="govuk-table__header">{{ t('pages.uploadEvidenceList.table.country') }}</th>
              <th scope="col" class="govuk-table__header">{{ t('pages.uploadEvidenceList.table.evidenceStatus') }}</th>
              <th scope="col" class="govuk-table__header">{{ t('pages.uploadEvidenceList.table.action') }}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for site in sites %}
              <tr class="govuk-table__row" data-testid="site-row-{{ site.siteId }}">
                <td class="govuk-table__cell">{{ site.siteName }}</td>
                <td class="govuk-table__cell">{{ site.country }}</td>
                <td class="govuk-table__cell" data-testid="evidence-status-{{ site.siteId }}">
                  <strong class="govuk-tag {{ site.evidenceStatusClass }}">{{ site.evidenceStatusText }}</strong>
                </td>
                <td class="govuk-table__cell" data-testid="action-{{ site.siteId }}">
                  {% if site.uploadUrl %}
                    <a href="{{ site.uploadUrl }}" class="govuk-link" data-testid="upload-link-{{ site.siteId }}">
                      {{ t('pages.uploadEvidenceList.uploadLink') }}
                      <span class="govuk-visually-hidden"> for {{ site.siteName }}</span>
                    </a>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        <form method="post" novalidate data-testid="continue-form">
          <input type="hidden" name="crumb" value="{{ crumb }}">
          <button type="submit" class="govuk-button" data-module="govuk-button" data-testid="continue-button">
            {{ t('pages.uploadEvidenceList.continueButton') }}
          </button>
        </form>
      {% else %}
        <p class="govuk-body" data-testid="no-sites-message">{{ t('pages.uploadEvidenceList.noSites') }}</p>
      {% endif %}

    </div>
  </div>
{% endblock %}
