{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" data-testid="error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
            <div class="govuk-error-summary__body">
              <p>{{ error }}</p>
            </div>
          </div>
        </div>
      {% else %}

        <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

        {% if queryNote %}
          <div class="govuk-inset-text" data-testid="query-note">
            <h2 class="govuk-heading-m">{{ t('pages.queryTaskList.queryNoteHeading') }}</h2>
            <p class="govuk-body">{{ queryNote }}</p>
          </div>
        {% endif %}

        <dl class="govuk-summary-list govuk-summary-list--no-border govuk-!-margin-bottom-6" data-testid="application-metadata">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.taskList.metadataYear') }}</dt>
            <dd class="govuk-summary-list__value" data-testid="metadata-year">{{ metadata.year }}</dd>
          </div>
        </dl>

        <ul class="govuk-task-list" data-testid="query-task-list">
          {% for task in tasks %}
            <li class="govuk-task-list__item govuk-task-list__item--with-link" data-testid="{{ task.testId }}">
              <div class="govuk-task-list__name-and-hint">
                <a class="govuk-link govuk-task-list__link" href="{{ task.url }}" data-testid="{{ task.testId }}-link">
                  {{ task.label }}
                </a>
              </div>
              <div class="govuk-task-list__status" data-testid="{{ task.testId }}-status">
                <strong class="govuk-tag {{ task.statusTagClass }}" data-testid="{{ task.testId }}-tag">
                  {{ task.statusTagText }}
                </strong>
              </div>
            </li>
          {% endfor %}
        </ul>

        <a href="{{ continueUrl }}" role="button" draggable="false" class="govuk-button" data-module="govuk-button" data-testid="continue-button">
          {{ t('pages.queryTaskList.continueButton') }}
        </a>

      {% endif %}

    </div>
  </div>
{% endblock %}
