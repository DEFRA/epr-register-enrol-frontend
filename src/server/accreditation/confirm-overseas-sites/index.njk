{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" data-testid="error-summary">
          <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
          <div class="govuk-error-summary__body">
            <p>{{ error }}</p>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      {% if sites.length === 0 %}
        <p class="govuk-body" data-testid="no-sites-message">
          {{ t('pages.confirmOverseasSites.noSites') }}
        </p>
      {% else %}
        <dl class="govuk-summary-list" data-testid="sites-list">
          {% for site in sites %}
            <div class="govuk-summary-list__row" data-testid="site-row-{{ site.SiteId }}">
              <dt class="govuk-summary-list__key" data-testid="site-name-{{ site.SiteId }}">{{ site.SiteName }}</dt>
              <dd class="govuk-summary-list__value" data-testid="site-country-{{ site.SiteId }}">{{ site.Country }}</dd>
              <dd class="govuk-summary-list__actions">
                <form method="post" style="display:inline" data-testid="remove-form-{{ site.SiteId }}">
                  <input type="hidden" name="crumb" value="{{ crumb }}">
                  <input type="hidden" name="siteId" value="{{ site.SiteId }}">
                  <button type="submit" name="submitAction" value="remove"
                          class="govuk-button govuk-button--warning govuk-!-margin-bottom-0"
                          data-testid="remove-button-{{ site.SiteId }}">
                    {{ t('pages.confirmOverseasSites.removeButton') }}
                  </button>
                </form>
              </dd>
            </div>
          {% endfor %}
        </dl>
      {% endif %}

      <form method="post" data-testid="confirm-form">
        <input type="hidden" name="crumb" value="{{ crumb }}">
        <button type="submit" name="submitAction" value="confirm"
                class="govuk-button" data-module="govuk-button"
                data-testid="confirm-button">
          {{ t('pages.confirmOverseasSites.confirmButton') }}
        </button>
      </form>

    </div>
  </div>
{% endblock %}
