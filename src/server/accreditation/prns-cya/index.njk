{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" data-testid="error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
            <div class="govuk-error-summary__body">
              <p>{{ error }}</p>
            </div>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      <dl class="govuk-summary-list" data-testid="summary-list">

        <div class="govuk-summary-list__row" data-testid="tonnage-row">
          <dt class="govuk-summary-list__key">{{ t('pages.prnsCya.tonnageLabel') }}</dt>
          <dd class="govuk-summary-list__value" data-testid="tonnage-value">{{ tonnageLabel }}</dd>
          <dd class="govuk-summary-list__actions">
            <a class="govuk-link" href="{{ changeTonnageLink }}" data-testid="change-tonnage-link">
              {{ t('pages.prnsCya.change') }}<span class="govuk-visually-hidden"> {{ t('pages.prnsCya.changeTonnageContext') }}</span>
            </a>
          </dd>
        </div>

        <div class="govuk-summary-list__row" data-testid="authorisers-row">
          <dt class="govuk-summary-list__key">{{ t('pages.prnsCya.authorisersLabel') }}</dt>
          <dd class="govuk-summary-list__value" data-testid="authorisers-value">{{ authorisersSummary }}</dd>
          <dd class="govuk-summary-list__actions">
            <a class="govuk-link" href="{{ changeAuthorityLink }}" data-testid="change-authority-link">
              {{ t('pages.prnsCya.change') }}<span class="govuk-visually-hidden"> {{ t('pages.prnsCya.changeAuthorityContext') }}</span>
            </a>
          </dd>
        </div>

      </dl>

      <form method="post" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}">

        <button type="submit" name="submitAction" value="confirm" class="govuk-button" data-module="govuk-button" data-testid="confirm-button">
          {{ t('pages.prnsCya.confirmAndContinue') }}
        </button>

        <p class="govuk-body">
          <button type="submit" name="submitAction" value="saveAndComeLater" class="govuk-link" data-testid="save-come-back-button">
            {{ t('pages.prnsCya.saveAndComeLater') }}
          </button>
        </p>

      </form>

    </div>
  </div>
{% endblock %}
