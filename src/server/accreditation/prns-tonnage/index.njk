{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if errors %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" data-testid="error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                {% if errors.plannedTonnageBand %}
                  <li>
                    <a href="#plannedTonnageBand-1">{{ errors.plannedTonnageBand.text }}</a>
                  </li>
                {% endif %}
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" data-testid="error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
            <div class="govuk-error-summary__body">
              <p>{{ error }}</p>
            </div>
          </div>
        </div>
      {% endif %}

      <form method="post" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}">

        <div class="govuk-form-group {% if errors.plannedTonnageBand %}govuk-form-group--error{% endif %}">
          <fieldset class="govuk-fieldset" {% if errors.plannedTonnageBand %}aria-describedby="plannedTonnageBand-error"{% endif %}>
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
              <h1 class="govuk-fieldset__heading" data-testid="page-heading">{{ heading }}</h1>
            </legend>

            {% if errors.plannedTonnageBand %}
              <p id="plannedTonnageBand-error" class="govuk-error-message" data-testid="field-error">
                <span class="govuk-visually-hidden">Error:</span>
                {{ errors.plannedTonnageBand.text }}
              </p>
            {% endif %}

            <div class="govuk-radios" data-module="govuk-radios" data-testid="tonnage-radios">
              {% for option in tonnageOptions %}
                <div class="govuk-radios__item">
                  <input
                    class="govuk-radios__input"
                    id="plannedTonnageBand-{{ loop.index }}"
                    name="plannedTonnageBand"
                    type="radio"
                    value="{{ option.value }}"
                    {% if option.checked %}checked{% endif %}
                    data-testid="tonnage-option-{{ option.value | lower }}">
                  <label class="govuk-label govuk-radios__label" for="plannedTonnageBand-{{ loop.index }}">
                    {{ option.text }}
                  </label>
                </div>
              {% endfor %}
            </div>
          </fieldset>
        </div>

        <button type="submit" name="submitAction" value="saveAndContinue" class="govuk-button" data-module="govuk-button" data-testid="continue-button">
          {{ t('pages.prnsTonnage.saveAndContinue') }}
        </button>

        <p class="govuk-body">
          <button type="submit" name="submitAction" value="saveAndComeLater" class="govuk-link" data-testid="save-come-back-button">
            {{ t('pages.prnsTonnage.saveAndComeLater') }}
          </button>
        </p>

      </form>

    </div>
  </div>
{% endblock %}
