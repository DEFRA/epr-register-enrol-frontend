{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ backLink }}" class="govuk-back-link" data-testid="back-link">{{ t('common.back') }}</a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" data-testid="error-summary">
          <h2 class="govuk-error-summary__title">{{ t('common.errorSummaryTitle') }}</h2>
          <div class="govuk-error-summary__body">
            <p>{{ error }}</p>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="page-heading">{{ heading }}</h1>

      <h2 class="govuk-heading-m" data-testid="sub-heading">{{ subHeading }}</h2>

      <dl class="govuk-summary-list" data-testid="percent-summary-list">

        {% for row in percentRows %}
          <div class="govuk-summary-list__row" data-testid="percent-row-{{ row.id }}">
            <dt class="govuk-summary-list__key">{{ row.label }}</dt>
            <dd class="govuk-summary-list__value" data-testid="percent-value-{{ row.id }}">{{ row.value }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="{{ row.changeLink }}" data-testid="change-percent-{{ row.id }}">
                {{ t('pages.businessPlanCya.change') }}<span class="govuk-visually-hidden"> {{ row.changeContext }}</span>
              </a>
            </dd>
          </div>
        {% endfor %}

        {% for row in detailRows %}
          <div class="govuk-summary-list__row" data-testid="detail-row-{{ row.id }}">
            <dt class="govuk-summary-list__key">{{ row.label }}</dt>
            <dd class="govuk-summary-list__value" data-testid="detail-value-{{ row.id }}">{{ row.value }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="{{ row.changeLink }}" data-testid="change-detail-{{ row.id }}">
                {{ t('pages.businessPlanCya.change') }}<span class="govuk-visually-hidden"> {{ row.changeContext }}</span>
              </a>
            </dd>
          </div>
        {% endfor %}

      </dl>

      <form method="post" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}">

        <button type="submit" name="submitAction" value="confirm" class="govuk-button" data-module="govuk-button" data-testid="confirm-button">
          {{ t('pages.businessPlanCya.confirmAndContinue') }}
        </button>

        <button type="submit" name="submitAction" value="saveAndComeLater" class="govuk-button govuk-button--secondary" data-module="govuk-button" data-testid="save-come-back-button">
          {{ t('pages.businessPlanCya.saveAndComeLater') }}
        </button>

      </form>

    </div>
  </div>
{% endblock %}
