{% extends "layouts/page.njk" %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: pageTitle
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">

        <p>{{t("pages.organisationList.description")}}</p>

        {% if error %}
        <div class="govuk-error-summary" aria-labelledby="error-summary-title" role="alert" tabindex="-1" data-module="govuk-error-summary">
          <h2 class="govuk-error-summary__title" id="error-summary-title">
            There is a problem
          </h2>
          <div class="govuk-error-summary__body">
            <p>{{ error }}</p>
          </div>
        </div>
        {% endif %}

        <h2>{{t("navigation.organisationList")}}</h2>

        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th class="govuk-table__header">{{t("pages.organisationList.orgId")}}</th>
              <th class="govuk-table__header">{{t("pages.organisationList.companyName")}}</th>
              <th class="govuk-table__header">{{t("pages.organisationList.registrationNumber")}}</th>
              <th class="govuk-table__header">{{t("pages.organisationList.businessType")}}</th>
              <th class="govuk-table__header">{{t("pages.organisationList.contact")}}</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for org in organisationsViewModel %}
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">{{ org.orgId }}</td>
              <td class="govuk-table__cell">
                <a href="/organisation-details/{{org.orgId}}" class="govuk-link">
                  {{ org.companyDetails.name }}
                </a>
              </td>
              <td class="govuk-table__cell">{{ org.companyDetails.registrationNumber }}</td>
              <td class="govuk-table__cell">{{ org.businessType }}</td>
              <td class="govuk-table__cell">
                {% if org.contactDetails and org.contactDetails.fullName %}
                  {{ org.contactDetails.fullName }}
                {% else %}
                  <span class="govuk-body-s">{{t("pages.organisationList.noContact")}}</span>
                {% endif %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>

      </div>
    </div>
  </div>

{% endblock %}
