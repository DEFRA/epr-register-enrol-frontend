{% extends 'layouts/page.njk' %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: pageTitle
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">
        <p class="govuk-body">{{ t('pages.operatorAccreditation.guidance001') }}</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>{{ t('pages.operatorAccreditation.guidance002') }}</li>
          <li>{{ t('pages.operatorAccreditation.guidance003') }}</li>
        </ul>
        <p class="govuk-body">{{ t('pages.operatorAccreditation.guidance004') }}</p>
        <p class="govuk-body">{{ t('pages.operatorAccreditation.guidance005') }}</p>
        <button type="submit" class="govuk-button" data-module="govuk-button">
          {{ t('pages.operatorAccreditation.apply') }}
        </button>
      </div>
    </div>
  </div>

{% endblock %}
