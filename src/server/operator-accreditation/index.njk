{% extends 'layouts/page.njk' %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <a href="{{ reExBackUrl }}" class="govuk-back-link" data-testid="reex-back-link">
        {{ t('pages.operatorAccreditation.reExBackLink') }}
      </a>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert">
          <h2 class="govuk-error-summary__title">{{ t('pages.operatorAccreditation.seedErrorHeading') }}</h2>
          <div class="govuk-error-summary__body">
            <p class="govuk-body" data-testid="error-message">{{ error }}</p>
          </div>
        </div>
      {% else %}
        <h1 class="govuk-heading-l" data-testid="page-heading">{{ organisationName }}</h1>

        <dl class="govuk-summary-list govuk-!-margin-bottom-6" data-testid="application-summary">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.operatorAccreditation.organisationLabel') }}</dt>
            <dd class="govuk-summary-list__value" data-testid="organisation-name">{{ organisationName }}</dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Registration Number </dt>
            <dd class="govuk-summary-list__value" data-testid="registration-number">{{ registrationReference }}</dd>
          </div>
          {% if not isExporter %}
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">{{ t('pages.operatorAccreditation.siteLabel') }}</dt>
              <dd class="govuk-summary-list__value" data-testid="site-name">{{ siteName }}</dd>
            </div>
          {% endif %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.operatorAccreditation.materialLabel') }}</dt>
            <dd class="govuk-summary-list__value" data-testid="material-display">{{ materialDisplay }}</dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.operatorAccreditation.yearLabel') }}</dt>
            <dd class="govuk-summary-list__value" data-testid="accreditation-year">{{ accreditationYear }}</dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('pages.operatorAccreditation.statusLabel') }}</dt>
            <dd class="govuk-summary-list__value" data-testid="application-status">
              <strong class="govuk-tag {{ statusTagClass }}" data-testid="status-tag">
                {{ statusLabel }}
              </strong>
            </dd>
          </div>
        </dl>

        <a href="{{ taskListUrl }}" role="button" draggable="false"
           class="govuk-button" data-module="govuk-button" data-testid="continue-button">
          {{ t('pages.operatorAccreditation.continueButton') }}
        </a>
      {% endif %}

    </div>
  </div>
{% endblock %}
