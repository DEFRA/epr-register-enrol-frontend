{% extends 'layouts/page.njk' %}

{% block content %}
  {{ appHeading({
    text: heading
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">
        <div class="govuk-body" data-testid="app-page-body">
          <h2 class="govuk-heading-m">{{ t('pages.operatorRegistrationBankDetails.pay_by_bank_transfer_heading') }}</h2>
          <p>{{ t('pages.operatorRegistrationBankDetails.payment_details_section') }}</p>

          <table class="govuk-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">{{ t('pages.operatorRegistrationBankDetails.england') }}</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              <tr class="govuk-table__row">
                <td align="left">{{ t('pages.operatorRegistrationBankDetails.england_account_name') }}</td>
              </tr>
              <tr class="govuk-table__row">
                <td align="left">{{ t('pages.operatorRegistrationBankDetails.england_account_number') }}</td>
