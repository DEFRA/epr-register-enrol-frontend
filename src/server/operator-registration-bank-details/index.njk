            </thead>
            <tbody class="govuk-table__body">
              <tr class="govuk-table__row">
                <td align="left">{{ t('pages.operatorRegistrationBankDetails.scotland_account_name') }}</td>
              </tr>
              <tr class="govuk-table__row">
