              <tr class="govuk-table__row">
                <td align="left">{{ t('pages.operatorRegistrationBankDetails.scotland_bank_name') }}</td>
              </tr>
            </tbody>
          </table>

		      <table class="govuk-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">{{ t('pages.operatorRegistrationBankDetails.northernireland') }}</th>
