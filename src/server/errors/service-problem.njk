{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l" data-testid="service-problem-heading">{{ pageTitle }}</h1>
      <p class="govuk-body">{{ t('common.errors.tryAgain') | capitalize }}</p>
      <p class="govuk-body">
        <a href="{{ retryUrl }}" class="govuk-link" data-testid="try-again-link">{{ t('common.errors.tryAgain') }}</a>
      </p>
    </div>
  </div>
{% endblock %}
