{% extends 'layouts/page.njk' %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: pageTitle
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">
        <p>{{t('pages.organisationDetails.description')}}</p>
          <ul>
            <li> {{t('pages.organisationDetails.companyName')}} : {{ orgDetailsViewModel.companyName }} </li>
            <li> {{t('pages.organisationDetails.organisationId')}} : {{ orgDetailsViewModel.regid}} </li>
            <li> {{t('pages.organisationDetails.companiesHouseNumber')}} : {{ orgDetailsViewModel.companiesHouseNumber }} </li>
            <li> {{t('pages.organisationDetails.registeredAddress')}} : {{ orgDetailsViewModel.registeredAddress }} </li>
            <li><p>
               <strong>Directors</strong>
               {% for director in orgDetailsViewModel.directors %}
                 <br/>{{ director.name }}
               {% endfor %}
            </li>
          </ul>
      </div>
    </div>
  </div>

{% endblock %}
