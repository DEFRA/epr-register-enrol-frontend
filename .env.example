# Copy this file to .env and fill in values for local development.
# .env is gitignored and loaded automatically by nodemon via --env-file-if-exists.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Auth — stub (default for local dev) ─────────────────────────────────────
AUTH_STUB_ENABLED=true
AUTH_CALLBACK_BASE_URL=http://localhost:3000

# ── Auth — Defra ID (operators, optional alongside stub) ────────────────────
# When set, a "Sign in with Defra ID" button appears on the stub chooser.
DEFRA_ID_CLIENT_ID=
DEFRA_ID_CLIENT_SECRET=
DEFRA_ID_DISCOVERY_URL=
DEFRA_ID_SERVICE_ID=

# ── Auth — Azure Entra ID (regulators, optional alongside stub) ─────────────
# When set, a "Sign in with Entra ID" button appears on the stub chooser.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── Auth — HTTP basic auth (optional infrastructure-level protection) ────────
AUTH_BASIC_ENABLED=false
BASIC_USER=
BASIC_PASSWD=

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_COOKIE_PASSWORD=the-password-must-be-at-least-32-characters-long

# ── API ──────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:5000
API_STUB_ENABLED=true

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
